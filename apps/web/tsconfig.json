{
  "extends": "../../tsconfig.base.json",
  "references": [
    {
      "path": "../../packages/ui"
    }
  ],
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "vite/client"
    ],
    "noEmit": true,
    "rootDirs": [
      ".",
      ".react-router/types"
    ],
    "paths": {
      "@/*": [
        "../../packages/ui/src/*"
      ],
      "~/*": [
        "./src/*"
      ]
    },
  },
  "include": [
    "src",
    ".react-router/types/**/*"
  ]
}